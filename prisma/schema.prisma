// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "sqlite"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
    player        Player?
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// ===== 游戏核心模型 =====

// 玩家游戏存档
model Player {
    id           String   @id @default(cuid())
    userId       String   @unique
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    name         String   // 角色名
    title        String   @default("领主") // 头衔（非职业）
    level        Int      @default(1)
    exp          Int      @default(0)
    currentWorld String   @default("main") // main/fire_realm/ice_realm/shadow_realm/celestial_realm

    // 职阶系统
    tier         Int      @default(1) // 职阶：1阶、2阶、3阶...

    // 体力系统（替代AP）
    stamina           Int      @default(100)
    maxStamina        Int      @default(100)
    staminaPerMin     Float    @default(0.2) // 每分钟回复量（可升级）
    lastStaminaUpdate DateTime @default(now()) // 上次体力更新时间

    // 资源
    gold     Int @default(100)
    wood     Int @default(50)
    stone    Int @default(30)
    food     Int @default(100)
    crystals Int @default(0)

    // 基础属性
    strength  Int @default(10)
    agility   Int @default(10)
    intellect Int @default(10)
    charisma  Int @default(10)

    // 结算相关
    lastSettlementDay Int      @default(0)  // 上次结算的游戏日
    currentDayScore   Int      @default(0)  // 当日累计分数
    streakDays        Int      @default(0)  // 连续达标天数

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // 关联
    characters       PlayerCharacter[]
    equipment        PlayerEquipment[]
    cards            PlayerCard[]
    buildings        PlayerBuilding[]
    storyProgress    StoryProgress[]
    unlockFlags      UnlockFlag[]
    economyLogs      EconomyLog[]
    militaryStatus   MilitaryStatus?
    profession       PlayerProfession?
    equippedItems    EquippedItem[]
    learnedSkills    PlayerSkill[]      // 已学习技能
    actionLogs       ActionLog[]        // 行动记录（用于结算）
    settlementLogs   SettlementLog[]    // 结算记录

    // 城外系统关联
    wildernessFacilities WildernessFacility[]
    exploredAreas        ExploredArea[]
    bossStatuses         BossStatus[]

    // 领地系统关联
    territoryTiles       TerritoryTile[]

    // 成就系统
    achievements         PlayerAchievement[]

    // 商店购买记录
    shopPurchases        ShopPurchase[]

    // 战斗记录
    combatSessions       CombatSession[]

    // 统计数据
    combatWins           Int @default(0)
    bossKills            Int @default(0)
    totalGoldEarned      Int @default(0)

    // 内城系统
    innerCityBuildings   InnerCityBuilding[]
    innerCityConfig      InnerCityConfig?

    // 外城系统
    heroInstances        HeroInstance[]
}

// 职业模板
model Profession {
    id          String @id @default(cuid())
    name        String @unique // 剑客、术士、商人等
    description String
    bonuses     String // JSON: 职业加成

    // 解锁条件（JSON格式）
    unlockConditions String // 如: {"skillLevel": {"剑术": 3}}

    playerProfessions    PlayerProfession[]
    characterProfessions CharacterProfession[]
}

// 玩家职业（可为空，通过突破卡获得）
model PlayerProfession {
    id           String     @id @default(cuid())
    playerId     String     @unique
    player       Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
    professionId String
    profession   Profession @relation(fields: [professionId], references: [id])
    obtainedAt   DateTime   @default(now())
}

// 角色模板
model Character {
    id          String  @id @default(cuid())
    name        String
    baseClass   String  // 初始职业类型：战士、农夫、工匠、学者
    rarity      String  // 普通、精英、稀有、传说
    portrait    String  // 头像emoji或图片路径
    description String
    story       String? // 背景故事

    // 基础属性
    baseAttack  Int
    baseDefense Int
    baseSpeed   Int
    baseLuck    Int
    baseHp      Int
    baseMp      Int

    // 初始特性
    traits String // JSON数组

    playerCharacters PlayerCharacter[]
}

// 玩家拥有的角色实例（可操作）
model PlayerCharacter {
    id          String    @id @default(cuid())
    playerId    String
    player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
    characterId String
    character   Character @relation(fields: [characterId], references: [id])

    // 职阶系统
    tier      Int    @default(1) // 职阶：决定技能槽数量（tier × 6）

    // 实例属性
    level     Int    @default(1)
    maxLevel  Int    @default(20)
    exp       Int    @default(0)
    hp        Int
    maxHp     Int
    mp        Int
    maxMp     Int
    status    String @default("idle") // idle/working/exploring/injured
    workingAt String? // 工作地点

    // 成长后的属性
    attack  Int
    defense Int
    speed   Int
    luck    Int

    // 好感度
    affection Int @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    // 关联
    profession    CharacterProfession?
    equippedItems EquippedItem[]
    learnedSkills CharacterSkill[]  // 已学习技能
    heroInstance  HeroInstance?     // 外城英雄实例
}

// 角色职业（可为空，通过突破卡获得）
model CharacterProfession {
    id                String          @id @default(cuid())
    playerCharacterId String          @unique
    playerCharacter   PlayerCharacter @relation(fields: [playerCharacterId], references: [id], onDelete: Cascade)
    professionId      String
    profession        Profession      @relation(fields: [professionId], references: [id])
    obtainedAt        DateTime        @default(now())
}

// 装备模板
model Equipment {
    id          String @id @default(cuid())
    name        String
    slot        String // mainHand/offHand/helmet/chest/belt/gloves/pants/boots/necklace/ring1/ring2
    rarity      String // 普通/精良/稀有/史诗/传说
    description String
    icon        String // emoji或图片

    // 基础属性加成
    attackBonus  Int @default(0)
    defenseBonus Int @default(0)
    speedBonus   Int @default(0)
    luckBonus    Int @default(0)
    hpBonus      Int @default(0)
    mpBonus      Int @default(0)

    // 特殊效果（JSON）
    specialEffects String?

    // 装备要求
    requiredLevel Int @default(1)

    playerEquipment PlayerEquipment[]
}

// 玩家拥有的装备实例
model PlayerEquipment {
    id          String    @id @default(cuid())
    playerId    String
    player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
    equipmentId String
    equipment   Equipment @relation(fields: [equipmentId], references: [id])

    // 强化等级
    enhanceLevel Int @default(0)

    createdAt DateTime @default(now())

    equippedOn EquippedItem?
}

// 装备穿戴关联（11槽位）
model EquippedItem {
    id                String           @id @default(cuid())
    playerEquipmentId String           @unique
    playerEquipment   PlayerEquipment  @relation(fields: [playerEquipmentId], references: [id], onDelete: Cascade)
    slot              String // mainHand/offHand/helmet/chest/belt/gloves/pants/boots/necklace/ring1/ring2

    // 装备到玩家或角色（二选一）
    playerId          String?
    player            Player?          @relation(fields: [playerId], references: [id], onDelete: Cascade)
    playerCharacterId String?
    playerCharacter   PlayerCharacter? @relation(fields: [playerCharacterId], references: [id], onDelete: Cascade)

    @@unique([playerId, slot])
    @@unique([playerCharacterId, slot])
}

// 卡牌模板
model Card {
    id          String @id @default(cuid())
    name        String @unique
    type        String // building/recruit/skill/enhance/item
    rarity      String // 普通/精良/稀有/史诗/传说
    description String
    icon        String @default("🃏")

    // 卡牌效果（JSON）
    // building: {buildingId, ...}
    // recruit: {characterId, ...}
    // skill: {skillId, ...}
    // enhance: {targetType, bonus, ...}
    // item: {itemType, effect, ...}
    effects     String

    playerCards PlayerCard[]
}

// 玩家拥有的卡牌
model PlayerCard {
    id       String @id @default(cuid())
    playerId String
    player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
    cardId   String
    card     Card   @relation(fields: [cardId], references: [id])
    quantity Int    @default(1)

    @@unique([playerId, cardId])
}

// 建筑模板
model Building {
    id          String @id @default(cuid())
    name        String
    slot        String // core/production/military/commerce/special
    icon        String
    description String
    maxLevel    Int

    // 基础效果（JSON）
    baseEffects String

    playerBuildings    PlayerBuilding[]
    innerCityBuildings InnerCityBuilding[]
}

// 玩家已建造建筑
model PlayerBuilding {
    id         String   @id @default(cuid())
    playerId   String
    player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
    buildingId String
    building   Building @relation(fields: [buildingId], references: [id])

    level         Int     @default(1)
    status        String  @default("idle") // idle/working/upgrading
    assignedCharId String? // 分配的角色ID

    positionX Int // 地图位置
    positionY Int

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([playerId, positionX, positionY])
}

// 剧情进度
model StoryProgress {
    id        String   @id @default(cuid())
    playerId  String
    player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
    storyId   String   // 剧情节点ID
    completed Boolean  @default(false)
    choices   String?  // JSON: 玩家选择记录
    completedAt DateTime?

    @@unique([playerId, storyId])
}

// 解锁标记
model UnlockFlag {
    id       String   @id @default(cuid())
    playerId String
    player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
    flagName String
    value    String   @default("true")
    unlockedAt DateTime @default(now())

    @@unique([playerId, flagName])
}

// 经济数据记录
model EconomyLog {
    id       String   @id @default(cuid())
    playerId String
    player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
    day      Int      // 游戏日
    date     DateTime @default(now())

    // 收入
    goldIncome     Int @default(0)
    woodIncome     Int @default(0)
    stoneIncome    Int @default(0)
    foodIncome     Int @default(0)
    crystalsIncome Int @default(0)

    // 支出
    goldExpense     Int @default(0)
    woodExpense     Int @default(0)
    stoneExpense    Int @default(0)
    foodExpense     Int @default(0)
    crystalsExpense Int @default(0)

    @@unique([playerId, day])
}

// 军事状态
model MilitaryStatus {
    id       String @id @default(cuid())
    playerId String @unique
    player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

    totalPower    Int @default(0) // 总战力
    defensePower  Int @default(0) // 防御力
    morale        Int @default(100) // 士气 (0-100)
    soldiers      Int @default(0) // 士兵数
    maxSoldiers   Int @default(10) // 士兵上限
    reserveSoldiers Int @default(0) // 预备兵

    // 威胁等级
    threatLevel String @default("low") // low/medium/high/critical

    // 周边威胁（JSON）
    nearbyThreats String @default("[]")

    updatedAt DateTime @updatedAt
}

// ===== 技能系统 =====

// 技能模板
model Skill {
    id          String @id @default(cuid())
    name        String @unique
    description String
    icon        String
    type        String // combat/production/utility
    category    String // sword/magic/crafting/etc

    // 技能效果（JSON）
    effects     String
    cooldown    Int    @default(0) // 冷却回合数

    // 升级数据（JSON：每级效果）
    levelData   String

    playerSkills    PlayerSkill[]
    characterSkills CharacterSkill[]
}

// 玩家已学习技能
model PlayerSkill {
    id        String @id @default(cuid())
    playerId  String
    player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
    skillId   String
    skill     Skill  @relation(fields: [skillId], references: [id])

    level     Int    @default(1)
    exp       Int    @default(0) // 技能熟练度

    createdAt DateTime @default(now())

    @@unique([playerId, skillId])
}

// 角色已学习技能
model CharacterSkill {
    id                String          @id @default(cuid())
    playerCharacterId String
    playerCharacter   PlayerCharacter @relation(fields: [playerCharacterId], references: [id], onDelete: Cascade)
    skillId           String
    skill             Skill           @relation(fields: [skillId], references: [id])

    level     Int    @default(1)
    exp       Int    @default(0)

    createdAt DateTime @default(now())

    @@unique([playerCharacterId, skillId])
}

// ===== 结算系统 =====

// 行动记录（用于计算当日分数）
model ActionLog {
    id       String   @id @default(cuid())
    playerId String
    player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

    day         Int      // 游戏日
    type        String   // build/explore/combat/upgrade/production/recruit
    description String
    baseScore   Int
    bonus       Int      @default(0)
    bonusReason String?
    timestamp   DateTime @default(now())

    @@index([playerId, day])
}

// 结算记录
model SettlementLog {
    id       String   @id @default(cuid())
    playerId String
    player   Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

    day        Int
    totalScore Int
    grade      String // S/A/B/C/D

    // 奖励（JSON）
    rewards    String

    // 分数明细（JSON）
    breakdown  String

    settledAt  DateTime @default(now())

    @@unique([playerId, day])
}

// ===== 城外系统 =====

// 野外设施实例
model WildernessFacility {
    id       String @id @default(cuid())
    playerId String
    player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
    worldId  String @default("main") // 所属世界

    type        String  // resource/monster/merchant/altar/portal
    name        String
    icon        String
    description String

    positionX   Int
    positionY   Int

    // 设施数据（JSON：奖励、商品、难度等）
    data        String

    // 状态
    remainingUses Int?     // 剩余使用次数（null=无限）
    expiresAt     DateTime? // 过期时间（null=永久）
    isDiscovered  Boolean  @default(false) // 是否已被发现

    createdAt DateTime @default(now())

    @@index([playerId, worldId])
    @@unique([playerId, worldId, positionX, positionY])
}

// 已探索区域（城外）
model ExploredArea {
    id       String @id @default(cuid())
    playerId String
    player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
    worldId  String @default("main")

    positionX        Int
    positionY        Int
    name             String
    biome            String  @default("grassland") // grassland/forest/mountain/desert/swamp
    explorationLevel Int     @default(2) // 0=hidden, 1=fog, 2=visible
    discoveredAt     DateTime @default(now())
    pendingEvent     String?  // JSON: server-generated event data, cleared after use

    @@index([playerId, worldId])
    @@unique([playerId, worldId, positionX, positionY])
}

// Boss模板
model Boss {
    id                 String  @id @default(cuid())
    name               String  @unique
    icon               String
    description        String
    level              Int
    hp                 Int
    attack             Int
    defense            Int
    skills             String  // JSON: Array<{name: string, damage: number, effect?: string}>
    weeklyAttemptLimit Int     @default(3)

    // 解锁条件
    requiredTier       Int     @default(0)
    requiredLevel      Int     @default(1)
    requiredWorld      String? // null = 主位面

    // 奖励
    rewardGold         Int
    rewardCrystals     Int
    rewardExp          Int
    rewardChestRarity  String
    rewardEquipRarity  String

    // 排序
    sortOrder          Int     @default(0)

    bossStatuses       BossStatus[]
}

// Boss状态
model BossStatus {
    id       String @id @default(cuid())
    playerId String
    player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
    bossId   String
    boss     Boss   @relation(fields: [bossId], references: [id], onDelete: Cascade)

    // 本周挑战次数
    weeklyAttempts Int      @default(0)
    lastAttempt    DateTime?
    lastDefeat     DateTime?

    // 每周一重置
    weekStartDate  DateTime

    @@index([playerId])
    @@unique([playerId, bossId])
}

// ===== 领地系统 =====

// 领地格子（已解锁的建筑位置）
model TerritoryTile {
    id       String @id @default(cuid())
    playerId String
    player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

    positionX Int
    positionY Int

    // 地形类型
    terrain   String @default("grass") // grass/dirt/water/road

    // 是否已解锁
    unlocked    Boolean  @default(false)
    unlockedAt  DateTime?

    // 解锁花费记录
    unlockCost  String?  // JSON: {gold: 100, wood: 50, ...}

    createdAt DateTime @default(now())

    @@index([playerId])
    @@unique([playerId, positionX, positionY])
}

// ===== 成就系统 =====

// 玩家已领取的成就
model PlayerAchievement {
    id            String   @id @default(cuid())
    playerId      String
    player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
    achievementId String   // 成就ID
    claimedAt     DateTime @default(now())

    @@unique([playerId, achievementId])
}

// ===== 商店系统 =====

// 商店购买记录（用于限购）
model ShopPurchase {
    id       String @id @default(cuid())
    playerId String
    player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
    itemId   String // 商品ID
    date     String // 日期字符串 (YYYY-MM-DD)
    quantity Int    @default(1)

    @@unique([playerId, itemId, date])
}

// ===== 战斗系统 =====

// 持久化的战斗会话
model CombatSession {
    id       String @id @default(cuid())
    playerId String
    player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

    // 战斗状态
    status       String @default("active") // active/victory/defeat/fled
    currentTurn  Int    @default(1)

    // 玩家方数据（JSON）
    playerTeam   String // JSON: [{id, name, hp, maxHp, mp, maxMp, ...}, ...]

    // 敌方数据（JSON）
    enemyTeam    String // JSON: [{id, name, hp, maxHp, attack, defense, ...}, ...]

    // 战斗配置
    combatType   String @default("normal") // normal/boss/pvp
    areaLevel    Int    @default(1)

    // 战斗日志（JSON数组）
    logs         String @default("[]")

    // 奖励数据（JSON，胜利后发放）
    rewards      String @default("{}")

    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    @@index([playerId])
}

// ===== 管理后台模型 =====

// 剧情章节（可通过Admin管理）
model StoryChapter {
    id          String      @id @default(cuid())
    title       String
    description String
    order       Int         @default(0)
    isActive    Boolean     @default(true)

    // 奖励配置 JSON: {gold?: number, crystals?: number, exp?: number, cards?: [{rarity, count}]}
    rewardsJson String      @default("{}")

    // 解锁条件 JSON: {level?: number, tier?: number, day?: number}
    unlockJson  String      @default("{}")

    nodes       StoryNode[]

    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt
}

// 剧情节点
model StoryNode {
    id          String       @id @default(cuid())
    chapterId   String
    chapter     StoryChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

    nodeId      String       // 节点标识符（用于跳转）
    title       String
    content     String
    speaker     String?
    speakerIcon String?
    order       Int          @default(0)

    // 下一节点ID（无选项时使用）
    nextNodeId  String?

    // 选项 JSON数组: [{text, nextNodeId, requirements?, rewards?}]
    choicesJson String?

    // 节点奖励 JSON: {gold?, crystals?, exp?}
    rewardsJson String?

    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt

    @@unique([chapterId, nodeId])
    @@index([chapterId])
}

// 奇遇事件（可通过Admin管理）
model Adventure {
    id          String  @id @default(cuid())
    name        String  @unique
    type        String  // resource/monster/treasure/merchant/trap/special

    // 出现条件
    minLevel    Int     @default(1)
    maxLevel    Int?
    worldId     String? // 指定世界，null表示所有世界
    weight      Int     @default(100) // 权重越高越容易出现
    isActive    Boolean @default(true)

    // 显示内容
    title       String
    description String
    icon        String  @default("❓")

    // 选项 JSON数组: [{text, action, cost?, requirement?}]
    optionsJson String

    // 奖励 JSON: {gold?, wood?, stone?, food?, exp?, cards?}
    rewardsJson String?

    // 怪物配置 JSON: {name, baseHp, baseAtk, baseDef, expReward, goldReward, cardChance}
    monsterJson String?

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
}

// ===== 内城系统 =====

// 内城建筑（自由放置，连续坐标）
model InnerCityBuilding {
    id         String   @id @default(cuid())
    playerId   String
    player     Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

    templateId String
    template   Building @relation(fields: [templateId], references: [id])

    positionX  Float
    positionY  Float
    level      Int      @default(1)

    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    @@index([playerId])
}

// 内城配置（圆角矩形领地）
model InnerCityConfig {
    id              String @id @default(cuid())
    playerId        String @unique
    player          Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

    territoryWidth  Float  @default(4.0)  // 半宽
    territoryHeight Float  @default(4.0)  // 半高
    cornerRadius    Float  @default(1.5)  // 圆角半径

    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt
}

// ===== 外城探索系统 =====

// 外城英雄实例
model HeroInstance {
    id          String   @id @default(cuid())
    playerId    String
    player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
    characterId String   @unique
    character   PlayerCharacter @relation(fields: [characterId], references: [id])

    positionX   Int      @default(0)
    positionY   Int      @default(0)
    status      String   @default("idle")  // idle/moving/exploring/fighting
    stamina     Int      @default(100)

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@index([playerId])
}

// 外城兴趣点
model OuterCityPOI {
    id          String   @id @default(cuid())
    positionX   Int
    positionY   Int
    name        String
    icon        String
    type        String   // resource/garrison/lair/settlement

    difficulty  Int      @default(1)

    resourceType   String?
    resourceAmount Int    @default(0)
    guardianLevel  Int    @default(0)

    isDefeated  Boolean  @default(false)
    defeatedAt  DateTime?
    respawnsAt  DateTime?

    @@unique([positionX, positionY])
}
